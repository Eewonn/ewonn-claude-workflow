{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "decision-log",
  "title": "Decision Log",
  "description": "Log of decisions and risks accumulated across a run.",
  "type": "object",
  "required": ["log_id", "run_id", "entries"],
  "additionalProperties": false,
  "properties": {
    "log_id": { "type": "string" },
    "run_id": { "type": "string" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "phase", "description", "status", "risk_level", "created_at"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "phase": { "type": "string", "enum": ["research", "plan", "implement", "validate"] },
          "description": { "type": "string" },
          "options": { "type": "array", "items": { "type": "string" } },
          "chosen_option": { "type": "string" },
          "rationale": { "type": "string" },
          "status": { "type": "string", "enum": ["open", "resolved", "deferred"] },
          "risk_level": { "type": "string", "enum": ["high", "medium", "low"] },
          "created_at": { "type": "string", "format": "date-time" },
          "resolved_at": { "type": "string", "format": "date-time" }
        },
        "if": {
          "properties": { "status": { "const": "resolved" } },
          "required": ["status"]
        },
        "then": {
          "required": ["resolved_at"]
        }
      }
    }
  }
}
